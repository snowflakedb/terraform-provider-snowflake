{{- /*gotype: github.com/Snowflake-Labs/terraform-provider-snowflake/pkg/acceptance/bettertestspoc/assert/resourceassert/gen.ResourceAssertionsModel*/ -}}

{{- $assertName := .Name | printf "%sResourceAssert" -}}
{{- $nameLowerCase := FirstLetterLowercase .Name -}}
{{- $assertVar := FirstLetter $nameLowerCase }}
//////////////////////////////////
// Attribute typed value checks //
//////////////////////////////////

{{ range .Attributes }}
    {{ if .ShouldGenerateTypedAssertion -}}
        func ({{ $assertVar }} *{{ $assertName }}) Has{{ SnakeCaseToCamel .Name }}(expected {{ .ExpectedType }}) *{{ $assertName }} {
            {{ $assertVar }}.{{ .AssertionCreator }}("{{ .Name }}", expected{{ if .IsCollection}}...{{ end }})
            return {{ $assertVar }}
        }

    {{ else -}}
        // typed assert for "{{ .Name }}" (type: {{ .Type }}{{ if .SubType }}, subtype: {{ .SubType }}{{ end }}) is not currently supported

    {{ end }}
{{ end }}

///////////////////////////////////
// Attribute value string checks //
///////////////////////////////////

{{ range .Attributes }}
    {{ if not .IsCollection -}}
    func ({{ $assertVar }} *{{ $assertName }}) Has{{ SnakeCaseToCamel .Name }}String(expected string) *{{ $assertName }} {
        {{ $assertVar }}.ValueSet("{{ .Name }}", expected)
        return {{ $assertVar }}
    }

    {{ end }}
{{ end }}

///////////////////////////////
// Attribute no value checks //
///////////////////////////////

{{ range .Attributes }}
    {{ if not .IsCollection -}}
    func ({{ $assertVar }} *{{ $assertName }}) HasNo{{ SnakeCaseToCamel .Name }}() *{{ $assertName }} {
        {{ $assertVar }}.ValueNotSet("{{ .Name }}")
        return {{ $assertVar }}
    }

    {{ end }}
{{ end }}

////////////////////////////
// Attribute empty checks //
////////////////////////////

{{ range .Attributes }}
    {{ if not .IsRequired }}
        func ({{ $assertVar }} *{{ $assertName }}) Has{{ SnakeCaseToCamel .Name }}Empty() *{{ $assertName }} {
            {{ if .IsCollection -}}
                {{ $assertVar }}.ValueSet("{{ .Name }}.#", "0")
                return {{ $assertVar }}
            {{ else -}}
                {{ $assertVar }}.ValueSet("{{ .Name }}", "")
                return {{ $assertVar }}
            {{ end -}}
        }

    {{ end }}
{{ end }}

///////////////////////////////
// Attribute presence checks //
///////////////////////////////

{{ range .Attributes -}}
    {{ if not .IsCollection }}
        func ({{ $assertVar }} *{{ $assertName }}) Has{{ SnakeCaseToCamel .Name }}NotEmpty() *{{ $assertName }} {
            {{ $assertVar }}.ValuePresent("{{ .Name }}")
            return {{ $assertVar }}
        }
    {{ end }}
{{ end -}}
