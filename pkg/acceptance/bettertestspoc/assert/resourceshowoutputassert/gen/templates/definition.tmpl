{{- /*gotype: github.com/Snowflake-Labs/terraform-provider-snowflake/pkg/acceptance/bettertestspoc/assert/resourceshowoutputassert/gen.ResourceShowOutputAssertionsModel*/ -}}

{{- $name := .Name }}
{{- $outputType := "Show"}}
{{- $assertName := $name | printf "%sShowOutputAssert" }}

{{- if .IsDescribeOutput }}
    {{- $name = TrimSuffix .Name "Details" }}

    {{- $outputType = "Describe" }}
    {{- $assertName = $name | printf "%sDescribeOutputAssert" }}
{{- end }}

{{- $outputTypeLowerCase := FirstLetterLowercase $outputType }}
{{- $assertVar := FirstLetterLowercase $name | printf "%sAssert" }}

type {{ $assertName }} struct {
    *assert.ResourceAssert
}

func {{ $name }}{{ $outputType }}Output(t *testing.T, name string) *{{ $assertName }} {
    t.Helper()

    {{ $assertVar }} := {{ $assertName }}{
        ResourceAssert: assert.NewResource{{ $outputType }}OutputAssert(name),
    }
    {{ $assertVar }}.AddAssertion(assert.ValueSet("{{ $outputTypeLowerCase }}_output.#", "1"))
    return &{{ $assertVar }}
}

func Imported{{ $name }}{{ $outputType }}Output(t *testing.T, id string) *{{ $assertName }} {
    t.Helper()

    {{ $assertVar }} := {{ $assertName }}{
        ResourceAssert: assert.NewImportedResource{{ $outputType }}OutputAssert(id),
    }
    {{ $assertVar }}.AddAssertion(assert.ValueSet("{{ $outputTypeLowerCase }}_output.#", "1"))
    return &{{ $assertVar }}
}

{{ if .DataSourceName }}
    func {{ .DataSourceName }}Datasource{{ $outputType }}Output(t *testing.T, name string) *{{ $assertName }} {
    t.Helper()

    return {{ .DataSourceName }}Datasource{{ $outputType }}OutputOnIdx(t, name, 0)
    }

    func {{ .DataSourceName }}Datasource{{ $outputType }}OutputOnIdx(t *testing.T, name string, idx int) *{{ $assertName }} {
    t.Helper()

    {{ $assertVar }} := {{ $assertName }}{
    ResourceAssert: assert.NewDatasource{{ $outputType }}OutputAssert(name, "{{ SnakeCase .DataSourceName }}", idx),
    }
    {{ $assertVar }}.AddAssertion(assert.ValueSet("{{ $outputTypeLowerCase }}_output.#", "1"))
    return &{{ $assertVar }}
    }
{{ end }}
