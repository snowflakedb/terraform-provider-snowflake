{{- /*gotype: github.com/Snowflake-Labs/terraform-provider-snowflake/pkg/acceptance/bettertestspoc/assert/resourceparametersassert/gen.ResourceParametersAssertionsModel*/ -}}

{{- $assertName := .Name | printf "%sResourceParametersAssert" -}}
{{- $nameLowerCase := FirstLetterLowercase .Name -}}
type {{ $assertName }} struct {
    *assert.ResourceAssert
}

func {{ .Name }}ResourceParameters(t *testing.T, name string) *{{ $assertName }} {
    t.Helper()

    resourceParameterAssert := {{ $assertName }}{
        ResourceAssert: assert.NewResourceParametersAssert(name),
    }
    return &resourceParameterAssert
}

func Imported{{ .Name }}ResourceParameters(t *testing.T, id string) *{{ $assertName }} {
    t.Helper()

    resourceParameterAssert := {{ $assertName }}{
        ResourceAssert: assert.NewImportedResourceParametersAssert(id),
    }
    return &resourceParameterAssert
}

{{ if .DataSourceName -}}
func {{ .DataSourceName }}DatasourceParameters(t *testing.T, name string) *{{ $assertName }} {
    t.Helper()

    return {{ .DataSourceName }}DatasourceParametersOnIdx(t, name, 0)
}

func {{ .DataSourceName }}DatasourceParametersOnIdx(t *testing.T, name string, idx int) *{{ $assertName }} {
    t.Helper()

    resourceParameterAssert := {{ $assertName }}{
        ResourceAssert: assert.NewDatasourceParametersAssert(name, "{{ SnakeCase .DataSourceName }}", idx),
    }
    return &resourceParameterAssert
}
{{ end -}}
