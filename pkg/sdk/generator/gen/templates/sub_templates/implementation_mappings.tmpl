{{- /*gotype: github.com/Snowflake-Labs/terraform-provider-snowflake/pkg/sdk/generator/gen.Interface*/ -}}

{{ range .Operations }}
    {{- if .OptsField }}
        func (r *{{ .OptsField.DtoDecl }}) toOpts() *{{ .OptsField.KindNoPtr }} {
            opts := &{{ template "toOptsMapping" .OptsField }}
            return opts
        }

        {{ if .ShowMapping }}
            {{ if not .ShowMapping.SkipConvert }}
                {{ template "convert" .ShowMapping }}
            {{ end }}
        {{ end }}

        {{ if .DescribeMapping }}
            {{ if not .DescribeMapping.SkipConvert }}
                {{ template "convert" .DescribeMapping }}
            {{ end }}
        {{ end }}

        {{ if .InstanceMethodMapping }}
            {{ if not .InstanceMethodMapping.SkipConvert }}
                {{ template "convert" .InstanceMethodMapping }}
            {{ end }}
        {{ end }}
    {{- end}}
{{ end }}

{{ range .SharedToOptsFields }}
    func (r *{{ .DtoDecl }}) toOpts() *{{ .KindNoPtr }} {
        opts := &{{ template "toOptsMapping" . }}
        return opts
    }
{{ end }}
