{{- /*gotype: github.com/Snowflake-Labs/terraform-provider-snowflake/pkg/sdk/generator/gen.Field*/ -}}

{{- $field := . -}}
{{- range .Validations }}
    {{- if .IsAdditionalValidations }}
        errs = append(errs, opts{{ $field.Path }}.additionalValidations())
    {{- else }}
        if {{ .Condition $field }} {
            errs = append(errs, {{ .ReturnedError $field }})
        }
    {{- end }}
{{- end -}}
{{- range .Fields }}
    {{- if .HasAnyValidationInSubtree }}
        if valueSet(opts{{ .Path }}) {
            {{- template "validationImplementation" . }}{{/* Recursive call */}}
        }
    {{- end -}}
{{- end -}}
